# /etc/rsyslog.d/hikvision.conf
# Recepción de logs del DVR Hikvision hacia Wazuh
# Servidor: 192.168.1.18 | DVR: 192.168.1.2

# Habilitar recepción UDP en puerto 514
module(load="imudp")
input(type="imudp" port="514")

# Escribir logs del DVR Hikvision a archivo dedicado
if $fromhost-ip == '192.168.1.2' then /var/log/hikvision-events.log
& stop
